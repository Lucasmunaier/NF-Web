rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function hasUidMap() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/uid_map/$(request.auth.uid));
    }

    function myUsername() {
      return get(/databases/$(database)/documents/uid_map/$(request.auth.uid)).data.username;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(myUsername())).data;
    }

    function isAdmin() {
      return hasUidMap() &&
             exists(/databases/$(database)/documents/users/$(myUsername())) &&
             getUserData().get('isAdmin', false) == true;
    }

    // UID → username mapping (cada usuário gerencia apenas o seu próprio)
    match /uid_map/{uid} {
      allow read, write: if isSignedIn() && uid == request.auth.uid;
    }

    // Processo de login via SILOMS
    match /auth_requests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Perfil especial do Admin (regra específica tem precedência)
    match /users/Admin {
      allow read, write: if isSignedIn() && hasUidMap() && myUsername() == 'Admin';
    }

    // Perfis de usuários (chave = username, não UID)
    match /users/{userId} {
      // Lê o próprio perfil via lookup uid_map → username
      allow get: if isSignedIn() && hasUidMap() && myUsername() == userId;
      // Admin lista todos
      allow list: if isAdmin();
      // Cria perfil próprio sem se promover a admin
      allow create: if isSignedIn() && hasUidMap() && myUsername() == userId
                    && request.resource.data.get('isAdmin', false) == false;
      // Atualiza o próprio perfil apenas para trocar o uid de sessão (preserva role/isAdmin)
      // ou Admin atualiza qualquer perfil
      allow update: if isAdmin() ||
                    (isSignedIn() && hasUidMap() && myUsername() == userId &&
                     request.resource.data.role == resource.data.role &&
                     request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false));
      allow delete: if false;
    }

    // Notas fiscais — acessa quem tem perfil válido
    match /notas_fiscais/{notaId} {
      allow read: if isSignedIn() && hasUidMap() &&
                  exists(/databases/$(database)/documents/users/$(myUsername()));
      allow write: if false;
    }

    // Fila de comandos para o worker
    match /command_queue/{cmdId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
