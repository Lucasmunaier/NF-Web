rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function hasUidMap() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/uid_map/$(request.auth.uid));
    }

    function myUsername() {
      return get(/databases/$(database)/documents/uid_map/$(request.auth.uid)).data.username;
    }

    function isAdmin() {
      return hasUidMap() &&
             exists(/databases/$(database)/documents/users/$(myUsername())) &&
             get(/databases/$(database)/documents/users/$(myUsername())).data.get('isAdmin', false) == true;
    }

    // UID → username mapping
    match /uid_map/{uid} {
      allow read, write: if isSignedIn() && uid == request.auth.uid;
    }

    // Processo de login via SILOMS
    match /auth_requests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Perfil especial do Admin — regra específica tem precedência
    match /users/Admin {
      allow read, write: if isSignedIn() && hasUidMap() && myUsername() == 'Admin';
    }

    // Perfis de usuários (chave = username, não UID)
    match /users/{userId} {
      // Leitura simples: qualquer usuário autenticado pode ler perfis
      // (necessário para o carregamento de perfil pós-login sem depender de uid_map)
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Cria perfil próprio sem poder se tornar admin
      allow create: if isSignedIn() && request.resource.data.get('isAdmin', false) == false;
      // Atualiza o próprio perfil apenas para trocar o uid de sessão (preserva role/isAdmin)
      // ou Admin atualiza qualquer perfil
      allow update: if isAdmin() ||
                    (isSignedIn() && hasUidMap() && myUsername() == userId &&
                     request.resource.data.role == resource.data.role &&
                     request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false));
      allow delete: if false;
    }

    // Notas fiscais — acessa quem tem perfil válido
    match /notas_fiscais/{notaId} {
      allow read: if isSignedIn() && hasUidMap() &&
                  exists(/databases/$(database)/documents/users/$(myUsername()));
      // Auditor, Aprovador e Admin podem alterar status (CONFERIDA, RETORNADA, etc.)
      allow update: if isSignedIn() && hasUidMap() &&
                    exists(/databases/$(database)/documents/users/$(myUsername())) &&
                    (get(/databases/$(database)/documents/users/$(myUsername())).data.role in ['Auditor', 'Aprovador'] ||
                     get(/databases/$(database)/documents/users/$(myUsername())).data.get('isAdmin', false) == true);
      // Apenas Auditor e Admin podem apagar notas
      allow delete: if isSignedIn() && hasUidMap() &&
                    exists(/databases/$(database)/documents/users/$(myUsername())) &&
                    (get(/databases/$(database)/documents/users/$(myUsername())).data.role == 'Auditor' ||
                     get(/databases/$(database)/documents/users/$(myUsername())).data.get('isAdmin', false) == true);
      allow create: if false;
    }

    // Fila de comandos para o worker
    match /command_queue/{cmdId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
